{
  "name": "vue3-vite-ts-project",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host --config vite.config.test.ts",
    "dev:prod": "vite --config vite.config.prod.ts",
    "build:test": "vite build --mode test --config vite.config.test.js",
    "build:prod": "vite build --mode production --config vite.config.prod.js",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "axios": "^1.12.2",
    "element-plus": "^2.11.5",
    "mitt": "^3.0.1",
    "pinia": "^3.0.3",
    "vue": "^3.5.22",
    "vue-i18n": "^11.1.12",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@types/node": "^24.6.0",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/tsconfig": "^0.8.1",
    "postcss-px-to-viewport-8-plugin": "^1.2.5",
    "postcss-pxtorem": "^6.1.0",
    "sass-embedded": "^1.93.2",
    "typescript": "~5.9.3",
    "unplugin-auto-import": "^20.2.0",
    "unplugin-vue-components": "^30.0.0",
    "vite": "npm:rolldown-vite@7.1.14",
    "vite-plugin-compression": "^0.5.1",
    "vue-tsc": "^3.1.0"
  },
  "pnpm": {
    "overrides": {
      "vite": "npm:rolldown-vite@7.1.14"
    }
  }
}
